# LLM
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat

# EMAIL (Resend)
RESEND_API_KEY=your_resend_key_here
RESEND_FROM_EMAIL=outreach@yourdomain.com
RESEND_REPLY_WEBHOOK_SECRET=any_random_string

# SMS (Africa's Talking)
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_key_here
AT_SENDER_ID=your_short_code

# HUBSPOT
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token

# CAL.COM
CALCOM_BASE_URL=http://localhost:3000
CALCOM_API_KEY=your_calcom_api_key
CALCOM_EVENT_TYPE_ID=1

# LANGFUSE
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# APP
APP_HOST=0.0.0.0
APP_PORT=8000
ENV=development

# TESTING
TEST_EMAIL=your_own_email@example.com
AT_TEST_NUMBER=+251900000000

# KILL SWITCH (unset by default — all outbound routes to staff sink)
# TENACIOUS_OUTBOUND_ENABLED=true

# LANGFUSE OTEL
LANGFUSE_BASE_URL=https://cloud.langfuse.com
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://cloud.langfuse.com/api/public/otel/v1/traces
OTEL_EXPORTER_OTLP_TRACES_PROTOCOL=http/protobuf
